{
  "meta": {
    "name": "theActCast Design Tokens",
    "direction": "rtl",
    "platforms": ["web-angular", "mobile-flutter"],
    "version": "1.0.0"
  },
  "color": {
    "brand": {
      "light": "#c1c1c1",
      "dark": "#3c4031"
    },
    "primary": {
      "50": "#f6f7f2",
      "100": "#eaede2",
      "200": "#d6dcc7",
      "300": "#b6bea2",
      "400": "#8d9778",
      "500": "#697257",
      "600": "#525845",
      "700": "#3c4031",
      "800": "#2f3227",
      "900": "#22241d"
    },
    "neutral": {
      "0": "#ffffff",
      "50": "#fcfbf9",
      "100": "#f4f2ee",
      "200": "#ece8e2",
      "300": "#ddd9d2",
      "400": "#c1c1c1",
      "500": "#98958f",
      "600": "#74716c",
      "700": "#575651",
      "800": "#383934",
      "900": "#23241f"
    },
    "surface": {
      "base": "#f7f5f1",
      "raised": "#ffffff",
      "sunken": "#eeece6",
      "overlay": "rgba(34, 36, 29, 0.68)"
    },
    "border": {
      "subtle": "#dfdbd4",
      "default": "#cbc6be",
      "strong": "#a9a49a"
    },
    "text": {
      "primary": "#1f211a",
      "secondary": "#5e6257",
      "muted": "#81867b",
      "inverse": "#f9f8f5"
    },
    "status": {
      "success": "#4f7a57",
      "warning": "#9a6a2e",
      "error": "#a34d4d",
      "info": "#4d667f"
    },
    "state": {
      "disabledBg": "#e7e4de",
      "disabledText": "#a09a91",
      "hover": "#eef1e7",
      "active": "#323628",
      "focus": "#788168"
    }
  },
  "typography": {
    "fontFamily": {
      "arabic": "Tajawal, Cairo, IBM Plex Sans Arabic, Segoe UI, sans-serif"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "scale": {
      "display": {
        "fontSize": 48,
        "lineHeight": 1.1,
        "weight": 700
      },
      "h1": {
        "fontSize": 40,
        "lineHeight": 1.2,
        "weight": 700
      },
      "h2": {
        "fontSize": 32,
        "lineHeight": 1.25,
        "weight": 700
      },
      "h3": {
        "fontSize": 24,
        "lineHeight": 1.3,
        "weight": 600
      },
      "h4": {
        "fontSize": 20,
        "lineHeight": 1.35,
        "weight": 600
      },
      "bodyLg": {
        "fontSize": 18,
        "lineHeight": 1.7,
        "weight": 400
      },
      "body": {
        "fontSize": 16,
        "lineHeight": 1.7,
        "weight": 400
      },
      "bodySm": {
        "fontSize": 14,
        "lineHeight": 1.65,
        "weight": 400
      },
      "caption": {
        "fontSize": 12,
        "lineHeight": 1.5,
        "weight": 500
      },
      "button": {
        "fontSize": 15,
        "lineHeight": 1.2,
        "weight": 600
      }
    }
  },
  "spacing": {
    "1": 8,
    "2": 16,
    "3": 24,
    "4": 32,
    "5": 40,
    "6": 48,
    "7": 56,
    "8": 64,
    "9": 72,
    "10": 80
  },
  "radius": {
    "sm": 12,
    "md": 18,
    "lg": 24,
    "xl": 32,
    "pill": 999
  },
  "shadow": {
    "sm": "0 12px 24px rgba(32, 36, 27, 0.08)",
    "md": "0 18px 40px rgba(32, 36, 27, 0.12)",
    "lg": "0 28px 72px rgba(32, 36, 27, 0.16)"
  },
  "layout": {
    "navbarHeight": 88,
    "sidebarWidth": 288,
    "contentMaxWidth": 1440,
    "formMaxWidth": 920
  },
  "breakpoints": {
    "desktop": 1280,
    "tablet": 1024,
    "mobile": 768
  },
  "components": {
    "button": {
      "height": {
        "sm": 40,
        "md": 48,
        "lg": 56
      }
    },
    "input": {
      "height": 56,
      "borderRadius": 18
    },
    "card": {
      "padding": 24,
      "borderRadius": 24
    },
    "avatar": {
      "sm": 32,
      "md": 48,
      "lg": 72
    }
  }
}
